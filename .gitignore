# ============================================================
# Fake Account Detection System — .gitignore
# ============================================================

# ----- Secrets & credentials -----
.env
*.pem

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ----- Virtual environments -----
venv/
.venv/
env/
.conda/

# ----- IDE / editor -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Trained model artefacts -----
# These are large binary files — regenerate with `python main.py`
saved_models/
catboost_info/

# ----- Generated / temporary files -----
training_output.txt
scripts/test_profiles.csv
*.log

# ----- OS files -----
.DS_Store
Thumbs.db
Desktop.ini

# ----- Jupyter -----
.ipynb_checkpoints/

# ----- Large datasets (optional — uncomment to exclude) -----
# data/fake_social_media_global_2.0_with_missing.xlsx
# data/LIMFADD.csv
